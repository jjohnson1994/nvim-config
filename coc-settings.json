{
  "suggest.echodocSupport": true,
  "suggest.maxCompleteItemCount": 20,
  "suggest.enablePreview": true,
  "suggest.autoTrigger": "always",
  "eslint.probe": [
    "vue",
    "javascript",
    "typescript",
    "typescriptreact",
    "svelte",
    "yaml"
  ],
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "yaml.format.enable": true,
  "yaml.format.printWidth": 80,
  "yaml.format.proseWrap": "always",
  "languageserver": {
    "terraform": {
      "command": "terraform-ls",
      "args": ["serve"],
      "filetypes": [
        "terraform",
        "tf"
      ],
      "initializationOptions": {},
      "settings": {}
    },
    "jest": {
      "module": "/Users/james.johnson/.nvm/versions/node/v14.18.1/bin/jest-lsp",
      "args": ["--node-ipc"],
      "filetypes": [
        "typescript",
        "javascript",
        "typescriptreact",
        "javascriptreact"
      ],
      "trace.server": "verbose"
    }
  },
  "suggest.completionItemKindLabels": {
    "keyword": "\uf1de Keyword",
    "variable": "\ue79b Variable",
    "value": "\uf89f Value",
    "operator": "\u03a8 Operator",
    "function": "\u0192 Function",
    "reference": "\ufa46 Reference",
    "constant": "\uf8fe Constant",
    "method": "\uf09a Method",
    "struct": "\ufb44 Struct",
    "class": "\uf0e8 Class",
    "interface": "\uf417 Interface",
    "text": "\ue612 Text",
    "enum": "\uf435 Enum",
    "enumMember": "\uf02b EnumMember",
    "module": "\uf40d Module",
    "color": "\ue22b Color",
    "property": "\ue624 Property",
    "field": "\uf9be Field",
    "unit": "\uf475 Unit",
    "event": "\ufacd Event",
    "file": "\uf723 File",
    "folder": "\uf114 Folder",
    "snippet": "\ue60b Snippet",
    "typeParameter": "\uf728 TypeParameter",
    "default": "\uf29c"
  },
  "coc.preferences.enableLinkedEditing": true
}
